 fn copy_first_obs_to_remaining(obs: &mut [u8], obs_stride: usize) {
-    let (first, rest) = obs.split_at_mut(obs_stride);
-    for chunk in rest.chunks_exact_mut(obs_stride) {
-        chunk.copy_from_slice(first);
+    if obs_stride == 0 {
+        return;
+    }
+
+    let lanes = obs.len() / obs_stride;
+    let mut initialized_lanes = 1;
+    while initialized_lanes < lanes {
+        let copy_lanes = initialized_lanes.min(lanes - initialized_lanes);
+        let initialized_len = initialized_lanes * obs_stride;
+        let copy_len = copy_lanes * obs_stride;
+        let (initialized, remaining) = obs.split_at_mut(initialized_len);
+        remaining[..copy_len].copy_from_slice(&initialized[..copy_len]);
+        initialized_lanes += copy_lanes;
     }
 }
 
